---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Affordable estate planning for busy people in Maryland. Flat-fee wills, trusts, and powers of attorney. Done in weeks, not months." } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Plan Simple</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />

    <!-- JSON-LD: LegalService -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LegalService",
      "name": "Plan Simple",
      "description": "Affordable flat-fee estate planning for busy families in Maryland. Wills, trusts, powers of attorney, and advance directives.",
      "url": "https://plansimple.law",
      "telephone": "+13018103549",
      "email": "carolyn@carolynelefant.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bethesda",
        "addressRegion": "MD",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "State",
        "name": "Maryland"
      },
      "priceRange": "$$",
      "openingHours": "Mo-Fr 09:00-17:00"
    }
    </script>
  </head>
  <body>
    <!-- Navigation -->
    <header class="bg-white border-b border-gray-100 sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-brand-teal font-serif text-2xl font-bold tracking-tight">
          Plan Simple
        </a>
        <div class="hidden md:flex items-center gap-8 text-sm font-medium text-brand-slate-light">
          <a href="/services" class="hover:text-brand-teal transition-colors">Services</a>
          <a href="/faq" class="hover:text-brand-teal transition-colors">FAQ</a>
          <a href="/about" class="hover:text-brand-teal transition-colors">About</a>
          <a href="/blog" class="hover:text-brand-teal transition-colors">Blog</a>
          <a href="/contact" class="bg-brand-coral text-white px-5 py-2 rounded-full hover:bg-brand-coral-dark transition-colors">
            Get Started
          </a>
        </div>
        <!-- Mobile menu button -->
        <button id="menu-toggle" class="md:hidden text-brand-slate" aria-label="Open menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden px-6 pb-4 flex flex-col gap-4 text-sm font-medium border-t border-gray-100">
        <a href="/services" class="py-2 hover:text-brand-teal">Services</a>
        <a href="/faq" class="py-2 hover:text-brand-teal">FAQ</a>
        <a href="/about" class="py-2 hover:text-brand-teal">About</a>
        <a href="/blog" class="py-2 hover:text-brand-teal">Blog</a>
        <a href="/contact" class="bg-brand-coral text-white px-5 py-2 rounded-full text-center hover:bg-brand-coral-dark">Get Started</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-brand-slate text-white mt-24">
      <div class="max-w-5xl mx-auto px-6 py-16">
        <div class="grid md:grid-cols-3 gap-12 mb-12">
          <div>
            <div class="font-serif text-2xl font-bold text-white mb-3">Plan Simple</div>
            <p class="text-gray-400 text-sm leading-relaxed">
              Affordable estate planning for busy families in Bethesda and throughout Maryland.
            </p>
          </div>
          <div>
            <h4 class="font-semibold text-sm uppercase tracking-wider text-gray-400 mb-4">Services</h4>
            <ul class="space-y-2 text-sm text-gray-300">
              <li><a href="/services/wills" class="hover:text-white transition-colors">Wills</a></li>
              <li><a href="/services/trusts" class="hover:text-white transition-colors">Living Trusts</a></li>
              <li><a href="/services/powers-of-attorney" class="hover:text-white transition-colors">Powers of Attorney</a></li>
              <li><a href="/services/advance-directives" class="hover:text-white transition-colors">Advance Directives</a></li>
              <li><a href="/services/family-plan" class="hover:text-white transition-colors">The Family Plan</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold text-sm uppercase tracking-wider text-gray-400 mb-4">Contact</h4>
            <ul class="space-y-2 text-sm text-gray-300">
              <li>Bethesda, Maryland</li>
              <li><a href="tel:+13018103549" class="hover:text-white transition-colors">(301) 810-3549</a></li>
              <li><a href="mailto:carolyn@carolynelefant.com" class="hover:text-white transition-colors">carolyn@carolynelefant.com</a></li>
              <li><a href="/contact" class="hover:text-white transition-colors">Schedule a Call</a></li>
            </ul>
          </div>
        </div>

        <div class="border-t border-gray-700 pt-8">
          <p class="text-gray-500 text-xs leading-relaxed">
            <strong class="text-gray-400">Attorney Advertising / Legal Disclaimer:</strong> The information on this website is for general informational purposes only and does not constitute legal advice. No attorney-client relationship is formed by visiting this website or submitting a contact form. Plan Simple is the law office of Carolyn Elefant, licensed in Maryland, Washington DC, and New York. Results may vary depending on your specific circumstances. &copy; {new Date().getFullYear()} Plan Simple. All rights reserved.
          </p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>
  </body>
</html>
